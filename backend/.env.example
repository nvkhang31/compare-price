NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/kis-prices

# KIS WTS API
KIS_STATIC_DATA_URL=https://trading.kisvn.vn/files/resources/symbol_static_data.json?v=YOUR_VERSION
KIS_API_BASE_URL=https://trading.kisvn.vn

# VNDirect API
VNDIRECT_API_URL=https://finfo-api.vndirect.com.vn

# TCBS API
TCBS_API_URL=https://apipubaws.tcbs.com.vn

# Scheduler
DAILY_SYNC_TIME=15:30
DAILY_SYNC_ENABLED=true

# Alerts
ALERT_CRITICAL_THRESHOLD=0.05
ALERT_WARNING_THRESHOLD=0.01

# CORS
CORS_ORIGIN=http://localhost:3000
