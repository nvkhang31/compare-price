NODE_ENV=production
PORT=10000

# Database — MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxx.mongodb.net/kis-prices?retryWrites=true&w=majority&appName=Cluster0

# KIS WTS API
KIS_STATIC_DATA_URL=https://trading.kisvn.vn/files/resources/symbol_static_data.json?v=89-23b1f8f
KIS_API_BASE_URL=https://trading.kisvn.vn

# VNDirect API
VNDIRECT_API_URL=https://finfo-api.vndirect.com.vn

# TCBS API
TCBS_API_URL=https://apipubaws.tcbs.com.vn

# Scheduler — chạy lúc 15:30 thứ 2-6
DAILY_SYNC_TIME=15:30
DAILY_SYNC_ENABLED=true

# Alerts
ALERT_CRITICAL_THRESHOLD=0.05
ALERT_WARNING_THRESHOLD=0.01

# CORS — điền Vercel URL sau khi deploy frontend
# VD: https://ten-app.vercel.app
CORS_ORIGIN=https://ten-app.vercel.app
